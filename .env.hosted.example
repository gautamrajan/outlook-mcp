# Outlook MCP Server — Hosted Mode Configuration
# Copy this to .env and fill in the values.

# ── Transport ─────────────────────────────────────────────
# Set to 'http' to enable HTTP transport (hosted mode)
# Default: 'stdio' (local mode)
MCP_TRANSPORT=http

# Port for the HTTP server (only used when MCP_TRANSPORT=http)
PORT=3000

# ── Microsoft Entra ID (Azure AD) ─────────────────────────
# These are from your Entra app registration.
OUTLOOK_TENANT_ID=your-tenant-id-here
OUTLOOK_CLIENT_ID=your-client-id-here
OUTLOOK_CLIENT_SECRET=your-client-secret-here

# ── Microsoft Graph API Scopes ─────────────────────────────
# Space-separated list of Graph API scopes.
# In hosted mode, offline_access is automatically filtered out for OBO flow.
# MS_SCOPES=offline_access Mail.Read Mail.ReadWrite User.Read Calendars.Read Calendars.ReadWrite Contacts.Read
