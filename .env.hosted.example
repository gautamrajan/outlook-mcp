# Outlook MCP Server — Hosted Mode Configuration
# Copy this to .env and fill in the values.

# ── Transport ─────────────────────────────────────────────
# Set to 'http' to enable HTTP transport (hosted mode)
MCP_TRANSPORT=http

# Port for the HTTP server
PORT=3000

# ── Microsoft Entra ID ────────────────────────────────────
OUTLOOK_TENANT_ID=your-tenant-id-here
OUTLOOK_CLIENT_ID=your-client-id-here
OUTLOOK_CLIENT_SECRET=your-client-secret-here

# ── Hosted Mode: Token & Session Storage ──────────────────
# Encryption key for at-rest token storage (required in hosted mode)
TOKEN_ENCRYPTION_KEY=your-strong-random-key-here
# Dev-only escape hatch (never use in production)
# ALLOW_INSECURE_TOKEN_STORE=false

# File paths for persistent storage (defaults shown)
# TOKEN_STORE_PATH=~/.outlook-mcp-hosted-tokens.json
# SESSION_STORE_PATH=~/.outlook-mcp-sessions.json

# ── Hosted Mode: Redirect URI ────────────────────────────
# The callback URL for browser auth flow (must match Entra app registration)
# HOSTED_REDIRECT_URI=https://your-server.com/auth/callback
