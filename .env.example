# Microsoft Azure App Registration Credentials
# Get these from Azure Portal > App Registrations > Your App

# Application (client) ID from Azure Portal
MS_CLIENT_ID=your-client-id-here

# Client secret VALUE (not the secret ID) from Azure Portal > Certificates & secrets
MS_CLIENT_SECRET=your-client-secret-here

# Optional: Enable test mode with mock data (true/false)
USE_TEST_MODE=false

# Connector Auth (Entra JWT + OBO)
# These are required when running in hosted mode behind a Claude Connector.

# Azure AD tenant ID (required for connector auth; 'common' won't work)
# MS_TENANT_ID=your-tenant-id-here

# Application ID URI of this app's Azure AD registration (e.g., api://your-client-id)
# Used as the expected 'aud' claim when validating incoming Entra JWTs.
MCP_API_APP_ID=api://your-client-id-here

# Custom scope exposed by this app (e.g., mcp.access)
# Used to validate the 'scp' claim in incoming Entra JWTs.
MCP_API_SCOPE=mcp.access

# Public HTTPS base URL for hosted deployments (used for PRM discovery and auth challenges)
# PUBLIC_BASE_URL=https://your-server.example.com

# Microsoft Graph scopes to request when exchanging tokens via OBO flow (space-separated)
OBO_SCOPES=Mail.Read Mail.Send Mail.ReadWrite Calendars.ReadWrite Contacts.Read User.Read

# Hosted session lifetime in days for browser-issued MCP bearer tokens
HOSTED_SESSION_EXPIRATION_DAYS=14
